# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Environment Variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env
client/.env

# ── Build Outputs ─────────────────────────────────────────────────────────────
client/dist/
client/build/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Uploads (local media, not for git) ───────────────────────────────────────
server/public/images/*
!server/public/images/.gitkeep
